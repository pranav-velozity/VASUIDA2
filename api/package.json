{
  "name": "velozity-uid-ops",
  "version": "1.0.0",
  "private": true,
  "description": "VelOzity Pinpoint UID Ops backend (Express + SQLite + SSE)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch server.js server.js",
    "health": "node -e \"require('http').get(process.env.API || 'http://localhost:4000/health', r=>r.pipe(process.stdout))\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@clerk/clerk-sdk-node": "^5.0.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "multer": "^2.1.1",
    "pdfkit": "^0.15.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
